                    </Button>
                    <Button onClick={handleSaveEdit} className="bg-green-600 hover:bg-green-700">
                      保存修改
                    </Button>
                    <Button onClick={handleCancelEdit} variant="outline" className="text-gray-400 border-slate-700/50 hover:text-white">
                      取消
                    </Button>
                  </div>
                </div>
              )}
            </>
          )}

          {/* 分析工作区 - 简化版本 */}
          {activeWorkbench === 'analysis' && (
            <>
              {/* 直接显示上传笔录和分析功能 */}
              <div className="bg-slate-900/20 border border-white/5 rounded-lg p-8 mb-8 shadow-lg shadow-black/20 backdrop-blur-sm">
                {/* 状态检查和AI分析按钮 */}
                <div className="grid grid-cols-2 gap-6 mb-8">
                  <div className={`p-6 rounded-lg ${
                    outlineData ? 'bg-green-900/20 border-green-800/30' : 'bg-slate-800/30 border-slate-700/50'
                  }`}>
                    <div className="flex items-center">
                      <Edit3 className="w-5 h-5 mr-3 text-green-400" />
                      <span className="font-medium text-white text-sm">访谈大纲</span>
                    </div>
                    <p className="text-gray-400 text-sm mt-2">
                      {outlineData ? '大纲已准备就绪' : '请先在"大纲设计"中生成大纲'}
                    </p>
                  </div>
                  
                  <div className={`p-6 rounded-lg ${
                    transcriptText ? 'bg-green-900/20 border-green-800/30' : 'bg-slate-800/30 border-slate-700/50'
                  }`}>
                    <div className="flex items-center">
                      <FileText className="w-5 h-5 mr-3 text-blue-400" />
                      <span className="font-medium text-white text-sm">访谈笔录</span>
                    </div>
                    <p className="text-gray-400 text-sm mt-2">
                      {transcriptText ? '笔录已上传' : '请上传访谈笔录'}
                    </p>
                  </div>
                </div>

                <Button 
                  onClick={analyzeTranscript}
                  disabled={!outlineData || !transcriptText || isAnalyzing || apiKeyStatus !== 'ready'}
                  className="w-full bg-blue-600 hover:bg-blue-700 mb-8"
                  size="lg"
                >
                  {isAnalyzing ? (
                    <>
                      <Loader2 className="w-4 h-4 mr-2 animate-spin" />
                      解析中...
                    </>
                  ) : (
                    <>
                      <Brain className="w-4 h-4 mr-2" />
                      运行洞察解析
                    </>
                  )}
                </Button>
                
                {/* 思考过程展示 */}
                {thinkingStep && (
                  <div className="bg-blue-900/20 border border-blue-800/30 rounded-lg p-4">
                    <div className="flex items-center">
                      <Brain className="w-4 h-4 text-blue-400 mr-3 animate-pulse" />
                      <span className="text-blue-300 text-sm">{thinkingStep}</span>
                    </div>
                  </div>
                )}
              </div>

              <div className="flex-1 overflow-y-auto p-8">
                {/* 分析结果 - 放在最上面 */}
                {analysisResult && (
                  <div className="space-y-8 mb-12">
                    {/* 背景段落 */}
                    <div className="relative">
                      <h4 className="font-medium text-white mb-4">【背景】</h4>
                      <p className="text-sm text-gray-300 bg-slate-800/30 p-6 rounded">
                        {analysisResult.background}
                      </p>
                      <Button
                        onClick={() => showFineTuneBubble('background')}
                        variant="ghost"
                        size="sm"
                        className="absolute top-0 right-0 text-gray-400 hover:text-blue-400"
                      >
                        <Sparkles className="w-3 h-3 mr-1" />
                        微调
                      </Button>
                      
                      {/* 微调气泡 */}
                      {fineTuneBubble?.section === 'background' && fineTuneBubble.isVisible && (
                        <div className="absolute top-12 right-0 z-10 bg-slate-800/90 border border-slate-700/50 rounded-lg p-4 shadow-lg w-96 backdrop-blur-sm">
                          <div className="space-y-4">
                            <div className="flex items-center justify-between">
                              <span className="text-sm font-medium text-white">微调内容</span>
                              <Button
                                onClick={hideFineTuneBubble}
                                variant="ghost"
                                size="sm"
                                className="text-gray-400 hover:text-white"
                              >
                                <X className="w-3 h-3" />
                              </Button>
                            </div>
                            <Textarea
                              value={fineTuneInstruction}
                              onChange={(e) => setFineTuneInstruction(e.target.value)}
                              placeholder="例如：这一段写得太专业了，请改得更通俗一点"
                              className="bg-slate-700/50 border-slate-600/50 text-white placeholder-gray-400 text-sm"
                              rows={3}
                            />
                            <div className="flex space-x-3">
                              <Button
                                onClick={() => handleFineTune('background')}
                                disabled={isFineTuning || !fineTuneInstruction.trim()}
                                size="sm"
                                className="bg-blue-600 hover:bg-blue-700"
                              >
                                {isFineTuning ? (
                                  <>
                                    <Loader2 className="w-3 h-3 mr-1 animate-spin" />
                                    处理中...
                                  </>
                                ) : (
                                  <>
                                    <Sparkles className="w-3 h-3 mr-1" />
                                    应用
                                  </>
                                )}
                              </Button>
                              <Button
                                onClick={hideFineTuneBubble}
                                variant="outline"
                                size="sm"
                                className="text-gray-400 border-slate-600/50 hover:text-white"
                              >
                                取消
                              </Button>
                            </div>
                          </div>
                        </div>
                      )}
                    </div>

                    {/* 访谈大纲段落 */}
                    <div className="relative">
                      <h4 className="font-medium text-white mb-4">【访谈大纲】</h4>
                      <p className="text-sm text-gray-300 bg-blue-900/20 p-6 rounded">
                        {analysisResult.outline}
                      </p>
                      <Button
                        onClick={() => showFineTuneBubble('outline')}
                        variant="ghost"
                        size="sm"
                        className="absolute top-0 right-0 text-gray-400 hover:text-blue-400"
                      >
                        <Sparkles className="w-3 h-3 mr-1" />
                        微调
                      </Button>
                      
                      {/* 微调气泡 */}
                      {fineTuneBubble?.section === 'outline' && fineTuneBubble.isVisible && (
                        <div className="absolute top-12 right-0 z-10 bg-slate-800/90 border border-slate-700/50 rounded-lg p-4 shadow-lg w-96 backdrop-blur-sm">
                          <div className="space-y-4">
                            <div className="flex items-center justify-between">
                              <span className="text-sm font-medium text-white">微调内容</span>
                              <Button
                                onClick={hideFineTuneBubble}
                                variant="ghost"
                                size="sm"
                                className="text-gray-400 hover:text-white"
                              >
                                <X className="w-3 h-3" />
                              </Button>
                            </div>
                            <Textarea
                              value={fineTuneInstruction}
                              onChange={(e) => setFineTuneInstruction(e.target.value)}
                              placeholder="例如：这一段写得太专业了，请改得更通俗一点"
                              className="bg-slate-700/50 border-slate-600/50 text-white placeholder-gray-400 text-sm"
                              rows={3}
                            />
                            <div className="flex space-x-3">
                              <Button
                                onClick={() => handleFineTune('outline')}
                                disabled={isFineTuning || !fineTuneInstruction.trim()}
                                size="sm"
                                className="bg-blue-600 hover:bg-blue-700"
                              >
                                {isFineTuning ? (
                                  <>
                                    <Loader2 className="w-3 h-3 mr-1 animate-spin" />
                                    处理中...
                                  </>
                                ) : (
                                  <>
                                    <Sparkles className="w-3 h-3 mr-1" />
                                    应用
                                  </>
                                )}
                              </Button>
                              <Button
                                onClick={hideFineTuneBubble}
                                variant="outline"
                                size="sm"
                                className="text-gray-400 border-slate-600/50 hover:text-white"
                              >
                                取消
                              </Button>
                            </div>
                          </div>
                        </div>
                      )}
                    </div>

                    {/* 核心观点段落 */}
                    <div className="relative">
                      <h4 className="font-medium text-white mb-4">【核心观点】</h4>
                      <p className="text-sm text-gray-300 bg-green-900/20 p-6 rounded">
                        {analysisResult.coreInsights}
                      </p>
                      <Button
                        onClick={() => showFineTuneBubble('coreInsights')}
                        variant="ghost"
                        size="sm"
                        className="absolute top-0 right-0 text-gray-400 hover:text-blue-400"
                      >
                        <Sparkles className="w-3 h-3 mr-1" />
                        微调
                      </Button>
                      
                      {/* 微调气泡 */}
                      {fineTuneBubble?.section === 'coreInsights' && fineTuneBubble.isVisible && (
                        <div className="absolute top-12 right-0 z-10 bg-slate-800/90 border border-slate-700/50 rounded-lg p-4 shadow-lg w-96 backdrop-blur-sm">
                          <div className="space-y-4">
                            <div className="flex items-center justify-between">
                              <span className="text-sm font-medium text-white">微调内容</span>
                              <Button
                                onClick={hideFineTuneBubble}
                                variant="ghost"
                                size="sm"
                                className="text-gray-400 hover:text-white"
                              >
                                <X className="w-3 h-3" />
                              </Button>
                            </div>
                            <Textarea
                              value={fineTuneInstruction}
                              onChange={(e) => setFineTuneInstruction(e.target.value)}
                              placeholder="例如：这一段写得太专业了，请改得更通俗一点"
                              className="bg-slate-700/50 border-slate-600/50 text-white placeholder-gray-400 text-sm"
                              rows={3}
                            />
                            <div className="flex space-x-3">
                              <Button
                                onClick={() => handleFineTune('coreInsights')}
                                disabled={isFineTuning || !fineTuneInstruction.trim()}
                                size="sm"
                                className="bg-blue-600 hover:bg-blue-700"
                              >
                                {isFineTuning ? (
                                  <>
                                    <Loader2 className="w-3 h-3 mr-1 animate-spin" />
                                    处理中...
                                  </>
                                ) : (
                                  <>
                                    <Sparkles className="w-3 h-3 mr-1" />
                                    应用
                                  </>
                                )}
                              </Button>
                              <Button
                                onClick={hideFineTuneBubble}
                                variant="outline"
                                size="sm"
                                className="text-gray-400 border-slate-600/50 hover:text-white"
                              >
                                取消
                              </Button>
                            </div>
                          </div>
                        </div>
                      )}
                    </div>

                    {/* 待办事项段落 */}
                    <div className="relative">
                      <h4 className="font-medium text-white mb-4">【待办事项】</h4>
                      <p className="text-sm text-gray-300 bg-yellow-900/20 p-6 rounded">
                        {analysisResult.actionItems}
                      </p>
                      <Button
                        onClick={() => showFineTuneBubble('actionItems')}
                        variant="ghost"
                        size="sm"
                        className="absolute top-0 right-0 text-gray-400 hover:text-blue-400"
                      >
                        <Sparkles className="w-3 h-3 mr-1" />
                        微调
                      </Button>
                      
                      {/* 微调气泡 */}
                      {fineTuneBubble?.section === 'actionItems' && fineTuneBubble.isVisible && (
                        <div className="absolute top-12 right-0 z-10 bg-slate-800/90 border border-slate-700/50 rounded-lg p-4 shadow-lg w-96 backdrop-blur-sm">
                          <div className="space-y-4">
                            <div className="flex items-center justify-between">
                              <span className="text-sm font-medium text-white">微调内容</span>
                              <Button
                                onClick={hideFineTuneBubble}
                                variant="ghost"
                                size="sm"
                                className="text-gray-400 hover:text-white"
                              >
                                <X className="w-3 h-3" />
                              </Button>
                            </div>
                            <Textarea
                              value={fineTuneInstruction}
                              onChange={(e) => setFineTuneInstruction(e.target.value)}
                              placeholder="例如：这一段写得太专业了，请改得更通俗一点"
                              className="bg-slate-700/50 border-slate-600/50 text-white placeholder-gray-400 text-sm"
                              rows={3}
                            />
                            <div className="flex space-x-3">
                              <Button
                                onClick={() => handleFineTune('actionItems')}
                                disabled={isFineTuning || !fineTuneInstruction.trim()}
                                size="sm"
                                className="bg-blue-600 hover:bg-blue-700"
                              >
                                {isFineTuning ? (
                                  <>
                                    <Loader2 className="w-3 h-3 mr-1 animate-spin" />
                                    处理中...
                                  </>
                                ) : (
                                  <>
                                    <Sparkles className="w-3 h-3 mr-1" />
                                    应用
                                  </>
                                )}
                              </Button>
                              <Button
                                onClick={hideFineTuneBubble}
                                variant="outline"
                                size="sm"
                                className="text-gray-400 border-slate-600/50 hover:text-white"
                              >
                                取消
                              </Button>
                            </div>
                          </div>
                        </div>
                      )}
                    </div>
                    
                    <div className="flex space-x-3 mt-8">
                      <Button onClick={exportFullReport} variant="outline" className="text-gray-400 border-slate-700/50 hover:text-white">
                        <Download className="w-4 h-4 mr-2" />
                        导出报告
                      </Button>
                    </div>
                  </div>
                )}

                {/* 笔录上传区域 */}
                <div className="border-2 border-dashed border-slate-700/50 rounded-lg p-8 mb-8">
                  <input
                    type="file"
                    accept=".txt,.docx"
                    onChange={handleFileUpload}
                    className="hidden"
                    id="file-upload"
                  />
                  <label 
                    htmlFor="file-upload" 
                    className="cursor-pointer inline-flex items-center space-x-3 px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors"
                  >
                    <Upload className="w-4 h-4" />
                    选择文件 (.txt/.docx)
                  </label>
                  <p className="text-sm text-gray-400 mt-3">或直接粘贴下方</p>
                </div>

                <div className="mb-8">
                  <Label className="text-gray-300 text-sm">访谈笔录内容</Label>
                  <Textarea
                    value={transcriptText}
                    onChange={(e) => setTranscriptText(e.target.value)}
                    className="min-h-40 mt-3 bg-slate-800/50 border-slate-700/50 text-white placeholder-gray-500"
                    placeholder="请粘贴访谈笔录内容..."
                  />
                </div>

                {/* 笔录预览区域 - 支持引用联动 */}
                {transcriptText && !analysisResult && (
                  <div className="bg-slate-800/30 rounded-lg p-6 shadow-lg shadow-black/20 backdrop-blur-sm" ref={transcriptRef}>
                    <h3 className="text-white font-medium mb-4">笔录预览</h3>
                    <div className="space-y-3 max-h-96 overflow-y-auto">
                      {transcriptChunks.map((chunk) => (
                        <div
                          key={chunk.id}
                          data-chunk-id={chunk.id}
                          className={`text-gray-300 text-sm p-3 rounded transition-all ${
                            highlightedChunkId === chunk.id 
                              ? 'bg-blue-900/30 ring-2 ring-blue-500 ring-opacity-50' 
                              : 'bg-slate-700/30'
                          }`}
                        >
                          {chunk.speaker && (
                            <span className="text-blue-400 font-medium">{chunk.speaker}：</span>
                          )}
                          <span className="whitespace-pre-wrap">{chunk.content}</span>
                        </div>
                      ))}
                    </div>
                  </div>
                )}
              </div>
            </>
          )}
        </div>
      </div>

      {/* 右侧：Agent 对话框 - 抽屉式展开 */}
      {!isRightSidebarCollapsed && (
        <div className="fixed right-0 top-0 h-full w-96 bg-slate-900/95 border-l border-slate-800/50 flex flex-col backdrop-blur-md z-50 transform transition-transform duration-300 ease-in-out">
          <div className="p-4 border-b border-slate-800/50">
            <div className="flex items-center justify-between">
              <div className="flex items-center">
                <div className={`w-8 h-8 bg-gradient-to-br from-purple-500 to-blue-500 rounded-full flex items-center justify-center mr-3 ${
                  isAnalyzing ? 'animate-spin' : ''
                }`}>
                  <Brain className="w-4 h-4 text-white" />
                </div>
                <div>
                  <h3 className="text-white font-medium text-sm">QualiProbe Agent</h3>
                  <p className="text-gray-400 text-xs">洞察引擎</p>
                </div>
              </div>
              <button
                onClick={() => setIsRightSidebarCollapsed(true)}
                className="text-gray-400 hover:text-white p-1"
              >
                <ChevronLeft className="w-4 h-4" />
              </button>
            </div>
          </div>
          
          {/* Agent 输出区域 - 洞察引擎开场白 */}
          <div className="flex-1 overflow-y-auto p-4">
            <div className="space-y-4">
              <div className="bg-blue-900/20 border border-blue-800/30 rounded-lg p-4">
                <h4 className="text-blue-300 font-medium mb-3 text-sm">洞察引擎</h4>
                <p className="text-blue-200 text-sm">
                  你好，我是 QualiProbe 洞察引擎。我已经准备好辅助你的定性研究。你可以让我根据你的研究目的优化大纲，或者直接上传笔录开始深度拆解。
                </p>
              </div>
              
              <div className="bg-purple-900/20 border border-purple-800/30 rounded-lg p-4">
                <h4 className="text-purple-300 font-medium mb-3 text-sm">智能关联</h4>
                <p className="text-purple-200 text-sm">
                  我已自动读取你的研究主题和目的。你可以直接问："基于目前这个主题，你觉得我的目标受众选对了吗？"
                </p>
              </div>
              
              <div className="bg-green-900/20 border border-green-800/30 rounded-lg p-4">
                <h4 className="text-green-300 font-medium mb-3 text-sm">精准溯源</h4>
                <p className="text-green-200 text-sm">
                  当你询问"原话"、"证据"等时，我会从笔录中提取100%还原的原文内容。
                </p>
              </div>
            </div>
          </div>
          
          {/* 实时对话框 */}
          <div className="border-t border-slate-800/50 p-4">
            <div className="space-y-3 max-h-64 overflow-y-auto mb-3">
              {chatMessages.map((message) => (
                <div
                  key={message.id}
                  className={`flex ${message.type === 'user' ? 'justify-end' : 'justify-start'}`}
                >
                  <div
                    className={`max-w-xs px-3 py-2 rounded-lg text-sm ${
                      message.type === 'user'
                        ? 'bg-blue-600 text-white'
                        : 'bg-slate-700/50 text-gray-200'
                    }`}
                  >
                    {message.content}
                    {/* 引用联动 - 可点击的原话 */}
                    {message.evidence && (
                      <button
                        onClick={() => scrollToEvidence(message.evidence!.chunkId)}
                        className="mt-2 text-blue-400 hover:text-blue-300 underline text-xs flex items-center"
                      >
                        <Search className="w-3 h-3 mr-1" />
                        查看原文位置
                      </button>
                    )}
                  </div>
                </div>
              ))}
            </div>
            
            {/* Agent 思考状态 - 状态透明化 */}
            {isAgentThinking && (
              <div className="flex items-center justify-center py-2">
                <div className="flex items-center space-x-2 text-blue-400 text-sm">
                  <Loader2 className="w-3 h-3 animate-spin" />
                  <span>{thinkingStep || '🔍 正在扫描笔录切片以获取证据...'}</span>
                </div>
              </div>
            )}
            
            <div className="flex space-x-2">
              <Input
                value={currentMessage}
                onChange={(e) => setCurrentMessage(e.target.value)}
                placeholder="追问更多细节..."
                className="bg-slate-800/50 border-slate-700/50 text-white placeholder-gray-500 text-sm"
                onKeyPress={(e) => e.key === 'Enter' && handleChat()}
              />
              <Button
                onClick={handleChat}
                disabled={!currentMessage.trim() || isChatting}
                className="bg-purple-600 hover:bg-purple-700"
              >
                <MessageSquare className="w-4 h-4" />
              </Button>
            </div>
          </div>
        </div>
      )}

      {/* 右侧收起状态 - 智能呼吸灯 */}
      {isRightSidebarCollapsed && (
        <div className="fixed right-0 top-1/2 transform -translate-y-1/2 bg-slate-800/50 border border-slate-700/50 rounded-l-lg p-2 text-gray-400 hover:text-white z-40 group">
          <button
            onClick={() => setIsRightSidebarCollapsed(false)}
            className={`text-gray-400 hover:text-white relative ${
              isAnalyzing ? 'animate-spin' : (analysisResult || chatMessages.length > 0 ? 'animate-pulse' : '')
            }`}
          >
            <MessageSquare className="w-5 h-5" />
            {/* 呼吸光圈 - 每3秒呼吸一次 */}
            <div className="absolute inset-0 rounded-full bg-blue-500/20 animate-pulse" style={{ animationDuration: '3s' }} />
            {/* 运转效果 - 分析进行时显示 */}
            {isAnalyzing && (
              <div className="absolute -top-1 -right-1 w-2 h-2 bg-gradient-to-r from-blue-500 to-purple-500 rounded-full animate-ping" />
            )}
            {/* 呼吸灯效果 - 当有新内容时显示 */}
            {!isAnalyzing && (analysisResult || chatMessages.length > 0) && (
              <div className="absolute -top-1 -right-1 w-2 h-2 bg-gradient-to-r from-blue-500 to-purple-500 rounded-full animate-ping" />
            )}
          </button>
          
          {/* 悬浮提示 */}
          <div className="absolute right-full top-1/2 transform -translate-y-1/2 mr-2 bg-slate-800/90 border border-slate-700/50 rounded-lg px-3 py-2 text-xs text-white opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none whitespace-nowrap backdrop-blur-sm">
            点击启动洞察解析
            <div className="absolute right-full top-1/2 transform -translate-y-1/2 w-0 h-0 border-t-4 border-t-transparent border-b-4 border-b-transparent border-r-4 border-r-slate-700/50"></div>
          </div>
        </div>
      )}

      {/* 全局错误Toast */}
      {showErrorToast && (
        <div className="fixed top-4 right-4 z-50 animate-in slide-in-from-right duration-300">
          <div className="bg-red-900/95 border border-red-700/50 rounded-lg p-4 shadow-2xl backdrop-blur-md max-w-sm">
            <div className="flex items-start">
              <div className="flex-shrink-0">
                <div className="w-6 h-6 bg-red-500 rounded-full flex items-center justify-center">
                  <X className="w-4 h-4 text-white" />
                </div>
              </div>
              <div className="ml-3">
                <h3 className="text-white font-medium text-sm">操作失败</h3>
                <p className="text-red-200 text-sm mt-1">{errorMessage}</p>
              </div>
              <div className="ml-auto pl-3">
                <button
                  onClick={() => setShowErrorToast(false)}
                  className="text-red-300 hover:text-white transition-colors"
                >
                  <X className="w-4 h-4" />
                </button>
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
