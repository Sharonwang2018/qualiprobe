          // 添加高亮动画
          chunkElement.classList.add('ring-2', 'ring-blue-500', 'ring-opacity-50');
          setTimeout(() => {
            chunkElement.classList.remove('ring-2', 'ring-blue-500', 'ring-opacity-50');
