            },
            {
              id: 4,
              title: "まとめと次のステップ",
              duration: "5分",
              questions: [
                "他に何か共有したいことはありますか",
                "追質問のため連絡してもよろしいですか"
              ],
              notes: "感謝の表明、要点の要約、次のステップの概要"
            }
          ]
        };
      } else if (outputLanguage === '双语对照') {
        result = {
          project_title: `${researchTopic} | Professional IDI Study`,
          sections: [
            {
              id: 1,
              title: "开场介绍 | Introduction & Rapport Building",
              duration: "10分钟 | 10 minutes",
              questions: [
                "请介绍一下您的背景 | Could you please introduce yourself and tell me about your background?",
                `您平时在什么情况下会想到${researchTopic || '产品/服务'}？| When do you usually think of ${researchTopic || 'product/service'}?`,
                "对今天的讨论有什么期待？| What are your expectations for today's discussion?"
              ],
              notes: "建立融洽氛围，说明保密性，设定预期 | Establish warm atmosphere, explain confidentiality, set expectations"
            },
            {
              id: 2,
              title: "核心体验探索 | Core Experience Exploration",
              duration: "25分钟 | 25 minutes",
              questions: [
                "能描述一下您的典型使用场景吗？| Could you walk me through your typical usage scenario?",
                "哪些方面运作良好？遇到什么挑战？| What aspects work well for you? What challenges do you encounter?",
                "与其他替代方案相比如何？| How does this compare to alternative solutions you've tried?"
              ],
              notes: "关注行为模式、痛点和决策标准 | Focus on behavioral patterns, pain points, and decision criteria"
            },
            {
              id: 3,
              title: "深度挖掘与未来需求 | Deep Dive & Future Needs",
              duration: "20分钟 | 20 minutes",
              questions: [
                "如果能改变一件事，会是什么？为什么？| If you could change one thing, what would it be and why?",
                "什么功能能让您的体验显著改善？| What features would make your experience significantly better?",
                "您认为未来6-12个月需求会如何变化？| How do you see your needs evolving in the next 6-12 months?"
              ],
              notes: "探索未满足需求、改进机会和未来期望 | Explore unmet needs, improvement opportunities, and future expectations"
            },
            {
              id: 4,
              title: "总结与后续步骤 | Wrap-up & Next Steps",
              duration: "5分钟 | 5 minutes",
              questions: [
                "还有其他想分享的吗？| Is there anything else you'd like to share?",
                "我可以联系您进行后续问题吗？| May I contact you for follow-up questions if needed?"
              ],
              notes: "表达感谢，总结要点，概述后续步骤 | Express gratitude, summarize key points, outline next steps"
            }
          ]
        };
      } else {
        // 默认中文版本
        result = {
          project_title: `${researchTopic} - 深度访谈大纲`,
          sections: [
            {
              id: 1,
              title: "开场介绍与热身",
              duration: "10分钟",
              questions: [
                "请先简单介绍一下您的背景",
                `您平时在什么情况下会想到${researchTopic || '产品/服务'}？`,
                "对今天的访谈有什么期待？"
              ],
              notes: "建立融洽氛围，说明访谈目的和保密性"
            },
            {
              id: 2,
              title: "核心使用体验",
              duration: "25分钟",
              questions: [
                `能描述一下您平时是如何使用${researchTopic || '产品/服务'}的吗？`,
                "在使用过程中，哪些方面让您觉得满意？哪些方面遇到了困难？",
                "与其他类似产品相比，您觉得有什么不同？"
              ],
              notes: "深入了解使用场景、痛点和决策因素"
            },
            {
              id: 3,
              title: "深度挖掘与需求探索",
              duration: "20分钟",
              questions: [
                "如果可以改变一个功能，您希望是什么？为什么？",
                "什么样的功能或改进能让您的体验变得更好？",
                "您认为未来6-12个月，您的需求会有什么变化？"
              ],
              notes: "探索潜在需求、改进机会和未来期望"
            },
            {
              id: 4,
              title: "总结与后续",
              duration: "5分钟",
              questions: [
                "还有其他想要分享的吗？",
                "如果后续有补充问题，方便联系您吗？"
              ],
              notes: "表达感谢，总结要点，说明后续安排"
            }
          ]
        };
      }

      setOutlineData(result);
      setIsEditing(false);
      
      // 保存到历史记录
      const newRecord: HistoryRecord = {
        id: Date.now().toString(),
        type: 'outline',
        title: result.project_title,
        data: result,
        timestamp: new Date()
      };
      
      setHistoryRecords(prev => [newRecord, ...prev].slice(0, 10));
    } catch (error) {
      console.error('生成失败:', error);
      showError('生成大纲失败，请检查网络连接后重试');
    } finally {
      setIsGenerating(false);
      setThinkingStep('');
    }
  };

  // 分析笔录
  const analyzeTranscript = async () => {
    if (!transcriptText.trim()) {
      showError('请输入访谈笔录');
      return;
    }

    setIsAnalyzing(true);
    setThinkingStep(`� 正在运用 ${researchTopic} 行业的专业视角分析访谈...`);
    
    // 微交互升级：触发Agent图标运转效果
    if (isRightSidebarCollapsed) {
      // 展开Agent以显示运转效果
      setIsRightSidebarCollapsed(false);
    }

    try {
      // 模拟AI分析步骤
      const steps = [
        '正在提取关键信息...',
        '正在分析用户需求...',
        '正在生成洞察报告...'
      ];

      for (let i = 0; i < steps.length; i++) {
        setThinkingStep(steps[i]);
        await new Promise(resolve => setTimeout(resolve, 1000));
      }

      // 模拟分析结果
      const mockResult: AnalysisResult = {
        background: `受访者是一位${targetAudience || '用户'}，在访谈中详细描述了关于${researchTopic || '相关产品'}的使用体验。访谈采用${interviewType === 'IDI' ? '深度访谈' : '焦点小组'}形式，时长约${interviewDuration}分钟。受访者表现出较高的参与度，提供了丰富的第一手资料。`,
        outline: `基于访谈内容，建议的研究大纲包括：1) 用户体验现状分析，重点关注使用场景和痛点；2) 需求层次挖掘，从功能需求到情感需求；3) 竞品对比分析，了解用户选择偏好；4) 改进建议收集，形成具体的优化方案。每个环节都应结合${researchPurpose || '研究目标'}进行深度探讨。`,
        coreInsights: `核心发现：1) 用户最关注的是${researchTopic || '产品'}的易用性和实用性；2) 存在明显的使用门槛，需要优化引导流程；3) 用户对个性化功能有强烈需求；4) 价格敏感度较高，性价比是重要考量因素。这些洞察为后续产品迭代提供了明确方向。`,
        actionItems: `后续行动建议：1) 进行更大规模的用户验证，确认洞察的普适性；2) 优先解决易用性问题，降低使用门槛；3) 深入研究个性化需求的具体场景；4) 分析竞品优势，制定差异化策略；5) 建立持续的用户反馈机制，跟踪需求变化。建议在2周内完成初步方案设计。`
      };

      setAnalysisResult(mockResult);
      
      // 保存到历史记录
      const newRecord: HistoryRecord = {
        id: Date.now().toString(),
        type: 'analysis',
        title: `${researchTopic} - 分析报告`,
        data: mockResult,
        timestamp: new Date()
      };
      
      setHistoryRecords(prev => [newRecord, ...prev].slice(0, 10));
    } catch (error) {
      console.error('分析失败:', error);
      showError('分析失败，请检查网络连接后重试');
    } finally {
      setIsAnalyzing(false);
      setThinkingStep('');
    }
  };

  // 增强版交互式对话 - 洞察引擎智能关联
  const handleChat = async () => {
    if (!currentMessage.trim()) return;

    // 首次交互时设置hasInteracted为true
    if (!hasInteracted) {
      setHasInteracted(true);
    }

    const userMessage: ChatMessage = {
      id: Date.now().toString(),
      type: 'user',
      content: currentMessage,
      timestamp: new Date()
    };

    setChatMessages((prev: ChatMessage[]) => [...prev, userMessage]);
    setCurrentMessage('');
    setIsChatting(true);
    setIsAgentThinking(true);

    try {
      // 模拟AI回复
      await new Promise(resolve => setTimeout(resolve, 1500));
      
      let responseContent = '';
      let evidence: { chunkId: string; text: string } | undefined;
      
      // 上下文自动喂养 - 静默背景注入
      const contextPrompt = `
【当前上下文】
- [当前页面模式]: ${activeWorkbench === 'outline' ? '大纲设计' : '访谈分析'}
- [研究主题]: ${researchTopic || '未填写'}
- [核心目标]: ${researchPurpose || '未填写'}
- [当前大纲快照]: ${outlineData ? JSON.stringify(outlineData.sections?.slice(0, 2)) : '无大纲数据'}

【用户问题】: ${currentMessage}

请基于以上上下文，以资深定性研究专家的身份回答。
`;
      
      // 检查是否需要进入【精准原文溯源模式】
      const needsOriginalText = currentMessage.includes('原话') || 
                              currentMessage.includes('原文') || 
                              currentMessage.includes('怎么说') || 
                              currentMessage.includes('具体说了') || 
                              currentMessage.includes('查看原话') || 
                              currentMessage.includes('提供证据') || 
                              currentMessage.includes('证据') || 
                              currentMessage.includes('结论来源') || 
                              currentMessage.includes('来源') ||
                              currentMessage.includes('谁说的');
      
      if (activeWorkbench === 'analysis' && analysisResult && needsOriginalText) {
        // 进入【精准原文溯源模式】 - 仅在分析页面且有笔录时
        setThinkingStep('🔍 正在扫描笔录切片以获取证据...');
        await new Promise(resolve => setTimeout(resolve, 1200));
        
        const keyword = currentMessage.replace(/原话|原文|怎么说|具体说了|查看原话|提供证据|证据|结论来源|来源|谁说的|关于|的|了|吗|？|。|！/g, '').trim();
        
        evidence = searchOriginalText(keyword);
        
        if (evidence) {
          // 强制引用格式 - 严禁概括
          responseContent = `『${evidence.text}』`;
        } else {
          // 诚实回答未找到
          responseContent = `在该段落中未发现关于"${keyword}"的具体原话。

建议尝试：
• 使用不同的关键词
• 检查相关段落
• 或者告诉我您想了解的具体方面`;
        }
      } else {
        // 洞察引擎智能关联模式
        const message = currentMessage.toLowerCase();
        
        // 检查是否在询问目标受众相关的问题
        if (message.includes('目标受众') || message.includes('受众') || message.includes('用户') || message.includes('选对')) {
          responseContent = `基于你当前的研究主题"${researchTopic || '未设置'}"和研究目的"${researchPurpose || '未设置'}"，我来分析一下目标受众的选择：

**当前目标受众：**${targetAudience || '未设置'}

**分析建议：**
1. 如果你的研究涉及${researchTopic || '产品'}的使用体验，${targetAudience || '目标受众'}是一个很好的起点
2. 建议进一步细分：可以考虑年龄层、使用频率、专业背景等维度
3. 如果${researchPurpose || '研究目的'}偏向深度挖掘，建议选择有3-6个月使用经验的用户

你觉得这个分析如何？需要我帮你优化受众定义吗？`;
        }
        // 检查是否在询问研究主题相关的问题
        else if (message.includes('主题') || message.includes('研究') || message.includes('方向')) {
          responseContent = `关于你的研究主题"${researchTopic || '未设置'}"，我有一些建议：

**主题分析：**
- 当前主题聚焦明确，有利于深度访谈
- 建议从以下角度深化：使用场景、痛点体验、改进期望

**优化建议：**
1. 可以考虑加入竞品对比维度
2. 如果是新产品研究，建议增加用户动机探索
3. 考虑不同用户群体的差异化需求

你想从哪个角度深入探讨？`;
        }
        // 检查是否在询问研究目的相关的问题
        else if (message.includes('目的') || message.includes('目标') || message.includes('想要')) {
          responseContent = `关于你的研究目的"${researchPurpose || '未设置'}"，我来帮你梳理：

**目的解析：**
- 目标清晰，有利于设计针对性问题
- 建议量化具体指标：如用户满意度提升X%、转化率提升Y%等

**执行建议：**
1. 可以拆分为3-4个具体的研究假设
2. 建议优先级排序：核心需求 > 次要需求 > 边缘需求
3. 考虑时间限制，聚焦最重要的2-3个目标

需要我帮你优化研究假设吗？`;
        }
        // 智能大纲优化建议
        else if (activeWorkbench === 'outline' && outlineData) {
          responseContent = `基于你当前的"${researchTopic || '研究主题'}"访谈大纲，我建议：

**大纲优化建议：**
1. **开场环节**：建议增加破冰问题，让受访者更放松
2. **主讨论环节**：可以加入具体的使用场景询问
3. **收尾环节**：建议补充"还有什么想补充的吗"

**问题质量提升：**
- 多用"能否描述一下..."替代"是否..."
- 增加"最满意/最不满意"的对比问题
- 考虑加入"如果有魔法棒，你最想改变什么"

你希望我帮你优化哪个环节？`;
        }
        // 分析工作台的专业建议
        else if (activeWorkbench === 'analysis') {
          if (analysisResult) {
            responseContent = `基于你的"${researchTopic || '研究主题'}"分析结果，我提供以下洞察：

**核心发现验证：**
- 你的研究目的"${researchPurpose || '未设置'}"在分析中得到了很好的回应
- 建议重点关注：${analysisResult.coreInsights.slice(0, 100)}...

**下一步行动：**
1. 可以基于这些洞察优化产品策略
2. 建议进行更大规模的用户验证
3. 考虑制定具体的改进时间表

需要我帮你制定详细的行动计划吗？`;
          } else {
            responseContent = `作为你的洞察引擎，我已准备好分析你的访谈内容：

**当前状态：**
- 研究主题：${researchTopic || '未设置'}
- 目标受众：${targetAudience || '未设置'}
- 研究目的：${researchPurpose || '未设置'}

**分析准备：**
请上传访谈笔录，我将为你提供：
1. 深度内容分析
2. 核心洞察提取
3. 行动建议制定

你的笔录准备好了吗？`;
          }
        }
        // 默认智能回复
        else {
          responseContent = `作为QualiProbe洞察引擎，我已读取你的研究信息：

**当前项目：**
- 主题：${researchTopic || '未设置'}
- 受众：${targetAudience || '未设置'}
- 目的：${researchPurpose || '未设置'}

**我可以帮你：**
• 优化访谈大纲设计
• 深度分析访谈内容
• 提供专业研究建议
• 提取精准原文证据

请告诉我你具体需要哪方面的帮助？`;
        }
      }
      
      const assistantMessage: ChatMessage = {
        id: (Date.now() + 1).toString(),
        type: 'assistant',
        content: responseContent,
        timestamp: new Date(),
        evidence
      };

      setChatMessages((prev: ChatMessage[]) => [...prev, assistantMessage]);
      scrollToChatBottom(); // 自动滚动到底部
    } catch (error) {
      console.error('对话失败:', error);
      showError('对话失败，请稍后重试');
    } finally {
      setIsChatting(false);
      setIsAgentThinking(false);
      setThinkingStep('');
      scrollToChatBottom(); // 确保滚动到底部
    }
  };

  // 编辑功能
  const handleEdit = () => {
    setEditingOutline(outlineData ? { ...outlineData } : null);
    setIsEditing(true);
  };

  const handleSaveEdit = () => {
    if (editingOutline) {
      setOutlineData(editingOutline);
      setIsEditing(false);
    }
  };

  const handleCancelEdit = () => {
    setIsEditing(false);
    setEditingOutline(null);
  };

  const handleSectionEdit = (index: number, field: keyof Section, value: any) => {
    if (!editingOutline) return;
    
    const updatedSections = [...editingOutline.sections];
    updatedSections[index] = {
      ...updatedSections[index],
      [field]: value
    };
    
    setEditingOutline({
      ...editingOutline,
      sections: updatedSections
    });
  };

  const addSection = () => {
    if (!editingOutline) return;
    
    const newSection: Section = {
      id: editingOutline.sections.length + 1,
      title: '新环节',
      duration: '15分钟',
      questions: ['请在此添加问题'],
      notes: '该环节的研究目的和注意事项'
    };
    
    setEditingOutline({
      ...editingOutline,
      sections: [...editingOutline.sections, newSection]
    });
  };

  const removeSection = (index: number) => {
    if (!editingOutline) return;
    
    const updatedSections = editingOutline.sections.filter((_, i) => i !== index);
    setEditingOutline({
      ...editingOutline,
      sections: updatedSections
    });
  };

  // 微调功能
  const handleFineTune = async (section: keyof AnalysisResult) => {
    if (!fineTuneInstruction.trim() || !analysisResult) return;

    setIsFineTuning(true);
    try {
      // 模拟AI微调
      await new Promise(resolve => setTimeout(resolve, 2000));
      
      const updatedResult = {
        ...analysisResult,
        [section]: `${analysisResult[section]}\n\n[微调后] 基于"${fineTuneInstruction}"的优化内容已添加。`
      };
      
      setAnalysisResult(updatedResult);
      setFineTuneBubble(null);
      setFineTuneInstruction('');
    } catch (error) {
      console.error('微调失败:', error);
      alert('微调失败，请重试');
    } finally {
      setIsFineTuning(false);
    }
  };

  const showFineTuneBubble = (section: keyof AnalysisResult) => {
    setFineTuneBubble({ section, isVisible: true });
  };

  const hideFineTuneBubble = () => {
    setFineTuneBubble(null);
    setFineTuneInstruction('');
  };

  // 导出功能
  const handleExport = () => {
    if (!outlineData) {
      alert('请先生成大纲');
      return;
    }
    exportToWord(outlineData);
  };

  // 导出完整报告
  const exportFullReport = () => {
    if (!analysisResult) {
      alert('请先完成分析');
      return;
    }

    const report = `
QualiProbe 调研报告
生成时间：${new Date().toLocaleString()}

【背景】
${analysisResult.background}

【访谈大纲】
${analysisResult.outline}

【核心观点】
${analysisResult.coreInsights}

【待办事项】
${analysisResult.actionItems}

${chatMessages.length > 0 ? `\n【深度对话】\n${chatMessages.map((msg: ChatMessage) => 
  `${msg.type === 'user' ? '用户' : 'AI Agent'}: ${msg.content}`
).join('\n\n')}` : ''}

原始笔录：
${transcriptText}
    `.trim();

    const blob = new Blob([report], { type: 'text/plain;charset=utf-8' });
    const url = URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = `QualiProbe_分析报告_${new Date().toISOString().split('T')[0]}.txt`;
    document.body.appendChild(a);
    a.click();
    document.body.removeChild(a);
    URL.revokeObjectURL(url);
  };

  // 从历史记录加载
  const loadFromHistory = (record: HistoryRecord) => {
    if (record.type === 'outline') {
      setOutlineData(record.data as OutlineData);
      setActiveWorkbench('outline');
    } else {
      setAnalysisResult(record.data as AnalysisResult);
      setActiveWorkbench('analysis');
    }
  };

  useEffect(() => {
    // 检查API密钥状态
    const checkApiKey = async () => {
      try {
        const apiKey = process.env.NEXT_PUBLIC_GROQ_API_KEY;
        if (apiKey) {
          setApiKeyStatus('ready');
        } else {
          setApiKeyStatus('error');
        }
      } catch (error) {
        setApiKeyStatus('error');
      }
    };

    checkApiKey();
  }, []);

  // 监听界面语言变化，同步更新output language
  useEffect(() => {
    if (language === 'zh') {
      setOutputLanguage('中文');
    } else {
      setOutputLanguage('英文');
    }
  }, [language]);

  return (
    <div className="min-h-screen bg-slate-50 text-slate-800 flex">
      {/* 左侧：项目记忆 - 收起状态 */}
      <div className={`${isLeftSidebarCollapsed ? 'w-10' : 'w-80'} bg-slate-50 border-r border-slate-200 flex flex-col transition-all duration-300`}>
        {!isLeftSidebarCollapsed ? (
          <>
            <div className="p-6 border-b border-slate-200">
              <div className="flex items-center justify-between">
                <div className="flex items-center">
                  <div className="w-8 h-8 bg-gradient-to-br from-blue-500 to-purple-500 rounded-full flex items-center justify-center mr-3">
                    <Brain className="w-4 h-4 text-white" />
                  </div>
                  <div>
                    <h3 className="text-slate-800 font-medium text-sm">{t('sidebar.projectMemory')}</h3>
                    <p className="text-slate-500 text-xs">{t('sidebar.historyRecords')}</p>
                  </div>
                </div>
                <button
                  onClick={() => setIsLeftSidebarCollapsed(true)}
                  className="text-slate-400 hover:text-slate-600 p-1"
                >
                  <ChevronLeft className="w-4 h-4" />
                </button>
              </div>
            </div>
            
            <div className="flex-1 overflow-y-auto p-6 space-y-6">
              <div className="bg-white border border-slate-200 rounded-lg p-4 shadow-sm">
                <h4 className="text-slate-800 font-medium mb-3 text-sm">{t('sidebar.currentSession')}</h4>
                <div className="space-y-3">
                  {outlineData && (
                    <div className="bg-white border border-slate-100 rounded-lg p-3 shadow-sm hover:shadow-md transition-shadow">
                      <div className="flex items-center justify-between">
                        <span className="text-xs px-2 py-1 rounded bg-blue-100 text-blue-700 font-medium">
                          {t('sidebar.outline')}
                        </span>
                        <span className="text-xs text-slate-500">
                          {new Date().toLocaleDateString()}
                        </span>
                      </div>
                      <h5 className="text-slate-800 text-sm font-medium truncate mt-2">{outlineData.project_title}</h5>
                    </div>
                  )}
                  
                  {transcriptChunks.length > 0 && (
                    <div className="bg-white border border-slate-100 rounded-lg p-3 shadow-sm hover:shadow-md transition-shadow">
                      <div className="flex items-center justify-between">
                        <span className="text-xs px-2 py-1 rounded bg-green-100 text-green-700 font-medium">
                          {t('sidebar.analysis')}
                        </span>
                        <span className="text-xs text-slate-500">
                          {new Date().toLocaleDateString()}
                        </span>
                      </div>
                      <h5 className="text-slate-800 text-sm font-medium truncate mt-2">{t('sidebar.transcriptAnalysis')}</h5>
                    </div>
                  )}
                </div>
              </div>
              
              <div className="bg-white border border-slate-200 rounded-lg p-4 shadow-sm">
                <h4 className="text-slate-800 font-medium mb-3 text-sm">{t('sidebar.history')}</h4>
                {historyRecords.length > 0 ? (
                  <div className="space-y-3">
                    {historyRecords.slice(0, 5).map((record) => (
                      <div
                        key={record.id}
                        onClick={() => loadFromHistory(record)}
                        className="bg-white border border-slate-100 rounded-lg p-3 cursor-pointer hover:shadow-md transition-all relative"
                      >
                        {/* 选中提示 - 左侧蓝紫色竖条 */}
                        <div className="absolute left-0 top-0 bottom-0 w-0.5 bg-gradient-to-b from-blue-500 to-purple-500 rounded-l"></div>
                        
                        <div className="flex items-center justify-between">
                          <span className={`text-xs px-2 py-1 rounded font-medium ${
                            record.type === 'outline' ? 'bg-blue-100 text-blue-700' : 'bg-green-100 text-green-700'
                          }`}>
                            {record.type === 'outline' ? t('sidebar.outline') : t('sidebar.analysis')}
                          </span>
                          <span className="text-xs text-slate-500">
                            {record.timestamp.toLocaleDateString()}
                          </span>
                        </div>
                        <h5 className="text-slate-800 text-sm font-medium truncate mt-2">{record.title}</h5>
                      </div>
                    ))}
                  </div>
                ) : (
                  <p className="text-slate-500 text-sm">{t('sidebar.noHistory')}</p>
                )}
              </div>
              
              {transcriptChunks.length > 0 && (
                <div className="bg-white border border-slate-200 rounded-lg p-4 shadow-sm">
                  <h4 className="text-slate-800 font-medium mb-3 text-sm">{t('sidebar.transcriptInfo')}</h4>
                  <div className="text-slate-600 text-sm space-y-1">
                    <div>{t('sidebar.chunksCount').replace('{{count}}', transcriptChunks.length.toString())}</div>
                    <div>{t('sidebar.avgLength').replace('{{length}}', Math.round(transcriptChunks.reduce((acc, chunk) => acc + chunk.content.length, 0) / transcriptChunks.length).toString())}</div>
                  </div>
                </div>
              )}
            </div>
          </>
        ) : (
          /* 收起状态 - 仅显示图标 */
          <div className="flex flex-col items-center py-6">
            <button
              onClick={() => setIsLeftSidebarCollapsed(false)}
              className="text-slate-400 hover:text-slate-600 p-2 mb-4"
            >
              <Clock className="w-5 h-5" />
            </button>
            <div className="text-gray-500 text-xs">{t('sidebar.memory')}</div>
          </div>
        )}
      </div>

      {/* 中间：主工作区 - 90% 宽度 */}
      <div className="flex-1 flex flex-col">
        {/* 顶部导航 - 极简处理 */}
        <div className="bg-white border-b border-slate-200 px-8 py-4 shadow-sm">
          <div className="flex items-center justify-between">
            <div>
              <h1 className={`text-2xl font-bold text-slate-800 mb-1 tracking-wider ${
                apiKeyStatus === 'ready' ? '' : 'text-slate-400 border border-red-300'
              }`}>{t('app.title')}</h1>
              <p className="text-slate-500 text-sm mb-3">{t('app.subtitle')}</p>
              
              {/* 工作台切换 - 放在标题下面 */}
              <div className="flex space-x-2 bg-slate-100 p-1 rounded-lg border border-slate-200">
                <button
                  onClick={() => setActiveWorkbench('outline')}
                  className={`px-3 py-1.5 rounded-md text-sm font-medium transition-all ${
                    activeWorkbench === 'outline' 
                      ? 'bg-blue-600 text-white' 
                      : 'text-slate-600 hover:text-slate-800'
                  }`}
                >
                  <Edit3 className="w-3.5 h-3.5 inline mr-1.5" />
                  {t('header.outlineDesign')}
                </button>
                <button
                  onClick={() => setActiveWorkbench('analysis')}
                  className={`px-3 py-1.5 rounded-md text-sm font-medium transition-all ${
                    activeWorkbench === 'analysis' 
                      ? 'bg-blue-600 text-white' 
                      : 'text-slate-600 hover:text-slate-800'
                  }`}
                >
                  <Brain className="w-3.5 h-3.5 inline mr-1.5" />
                  {t('header.interviewAnalysis')}
                </button>
              </div>
            </div>
            
            {/* 语言切换按钮 */}
            <div className="flex items-center space-x-3">
              <button
                onClick={() => setLanguage(language === 'zh' ? 'en' : 'zh')}
                className="flex items-center space-x-2 px-3 py-2 bg-slate-100 hover:bg-slate-200 rounded-lg transition-colors"
              >
                <Globe className="w-4 h-4 text-slate-600" />
                <span className="text-sm font-medium text-slate-700">
                  {language === 'zh' ? 'ZH' : 'EN'}
                </span>
              </button>
            </div>
          </div>
        </div>

        {/* 主工作区 */}
        <div className="flex-1 overflow-y-auto p-8 bg-slate-50">
          {activeWorkbench === 'outline' && (
            <>
              {/* 参数设置区 - 光影微调 */}
              <div className="bg-white border border-slate-200 rounded-lg p-8 mb-8 shadow-lg">
                <div className="grid grid-cols-2 gap-8">
                  <div>
                    <Label className="text-slate-600 text-sm">{t('outline.researchTopic')}</Label>
                    <Input
                      value={researchTopic}
                      onChange={(e) => setResearchTopic(e.target.value)}
                      className="mt-3 bg-white border border-slate-300 text-slate-800 placeholder-slate-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20"
                      placeholder={t('outline.researchTopicPlaceholder')}
                    />
                  </div>
                  
                  <div>
                    <Label className="text-slate-600 text-sm">{t('outline.targetAudience')}</Label>
                    <Input
                      value={targetAudience}
                      onChange={(e) => setTargetAudience(e.target.value)}
                      className="mt-3 bg-white border border-slate-300 text-slate-800 placeholder-slate-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20"
                      placeholder={t('outline.targetAudiencePlaceholder')}
                    />
                  </div>
                  
                  <div>
                    <Label className="text-slate-600 text-sm">{t('outline.researchPurpose')}</Label>
                    <Textarea
                      value={researchPurpose}
                      onChange={(e) => setResearchPurpose(e.target.value)}
                      className="min-h-40 mt-3 bg-white border border-slate-300 text-slate-800 placeholder-slate-400 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20"
                      placeholder={t('outline.researchPurposePlaceholder')}
                      rows={3}
                    />
                  </div>
                  
                  <div>
                    <Label className="text-slate-600 text-sm">{t('outline.interviewType')}</Label>
                    <Select value={interviewType} onValueChange={(value: 'IDI' | 'FGD') => setInterviewType(value)}>
                      <SelectTrigger className="mt-3 bg-white border border-slate-300 text-slate-800 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20">
                        <SelectValue />
                      </SelectTrigger>
                      <SelectContent className="bg-white border border-slate-200">
                        <SelectItem value="IDI" className="text-slate-800">{t('interviewTypes.idi')}</SelectItem>
                        <SelectItem value="FGD" className="text-slate-800">{t('interviewTypes.fgd')}</SelectItem>
                      </SelectContent>
                    </Select>
                  </div>
                    
                  <div>
                    <Label className="text-slate-600 text-sm">{t('outline.interviewDuration')}</Label>
                    <Select value={interviewDuration} onValueChange={setInterviewDuration}>
                      <SelectTrigger className="mt-3 bg-white border border-slate-300 text-slate-800 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20">
                        <SelectValue />
                      </SelectTrigger>
                      <SelectContent className="bg-white border border-slate-200">
                        <SelectItem value="30" className="text-slate-800">{t('durations.30')}</SelectItem>
                        <SelectItem value="45" className="text-slate-800">{t('durations.45')}</SelectItem>
                        <SelectItem value="60" className="text-slate-800">{t('durations.60')}</SelectItem>
                        <SelectItem value="90" className="text-slate-800">{t('durations.90')}</SelectItem>
                        <SelectItem value="120" className="text-slate-800">{t('durations.120')}</SelectItem>
                      </SelectContent>
                    </Select>
                  </div>
                  
                  <div>
                    <Label className="text-slate-600 text-sm flex items-center">
                      <span className="mr-2">🌐</span>
                      {t('outline.outputLanguage')}
                    </Label>
                    <div className="relative">
                      <button
                        onClick={() => setShowLanguageDropdown(!showLanguageDropdown)}
                        className="mt-3 w-full bg-white border border-slate-300 text-slate-800 rounded-lg px-4 py-3 text-left flex items-center justify-between hover:bg-slate-50 transition-all duration-200 focus:border-blue-500 focus:ring-2 focus:ring-blue-500/20"
                      >
                        <span className="flex items-center">
                          {outputLanguage === '中文' && (language === 'zh' ? '🇨🇳 中文' : '🇨🇳 Chinese')}
                          {outputLanguage === '英文' && (language === 'zh' ? '🇺🇸 英文' : '🇺🇸 English')}
                          {outputLanguage === '日文' && (language === 'zh' ? '🇯🇵 日文' : '🇯🇵 Japanese')}
                          {outputLanguage === '双语对照' && (language === 'zh' ? '🌐 双语对照' : '🌐 Bilingual')}
                        </span>
                        <ChevronDown className={`w-4 h-4 transition-transform duration-200 ${showLanguageDropdown ? 'rotate-180' : ''}`} />
                      </button>
                      
                      {showLanguageDropdown && (
                        <div className="absolute top-full left-0 right-0 mt-2 bg-white border border-slate-200 rounded-lg shadow-2xl z-50">
                          <div className="py-2">
                            {[
                              { value: '中文', label: language === 'zh' ? '🇨🇳 中文' : '🇨🇳 Chinese' },
                              { value: '英文', label: language === 'zh' ? '🇺🇸 英文' : '🇺🇸 English' },
                              { value: '日文', label: language === 'zh' ? '🇯🇵 日文' : '🇯🇵 Japanese' },
                              { value: '双语对照', label: language === 'zh' ? '🌐 双语对照' : '🌐 Bilingual' }
                            ].map((option) => (
                              <button
                                key={option.value}
                                onClick={() => {
                                  setOutputLanguage(option.value as '中文' | '英文' | '日文' | '双语对照');
                                  setShowLanguageDropdown(false);
                                }}
                                className={`w-full px-4 py-3 text-left hover:bg-slate-50 transition-colors duration-150 flex items-center ${
                                  outputLanguage === option.value ? 'bg-blue-50 text-blue-600' : 'text-slate-800'
                                }`}
                              >
                                {option.label}
                                {outputLanguage === option.value && (
                                  <Check className="w-4 h-4 ml-auto" />
                                )}
                              </button>
                            ))}
                          </div>
                        </div>
                      )}
                    </div>
                  </div>
                  
                  {/* 模板上传区域 */}
                  <div className="col-span-2">
                    <Label className="text-slate-600 text-sm flex items-center">
                      <span className="mr-2">📋</span>
                      {t('outline.templateUpload')}
                    </Label>
                    <div className="mt-3 grid grid-cols-2 gap-4">
                      <div>
                        <input
                          type="file"
                          accept=".json,.txt"
                          onChange={handleTemplateUpload}
                          className="hidden"
                          id="template-upload"
                        />
                        <Button
                          onClick={() => document.getElementById('template-upload')?.click()}
                          variant="outline"
                          className="w-full border-slate-300 text-slate-600 hover:text-slate-800 hover:border-slate-400"
                        >
                          <Upload className="w-4 h-4 mr-2" />
                          {t('outline.uploadTemplate')}
                        </Button>
                      </div>
                      
                      <div>
                        <Button
                          onClick={() => {
                            setSelectedTemplate('basic');
                            alert('已切换到默认模板');
                          }}
                          variant="outline"
                          className="w-full border-slate-300 text-slate-600 hover:text-slate-800 hover:border-slate-400"
                        >
                          <FileText className="w-4 h-4 mr-2" />
                          {t('outline.useDefaultTemplate')}
                        </Button>
                      </div>
                    </div>
                    <p className="text-slate-500 text-xs mt-2">{t('outline.templateSupport')}</p>
                  </div>
                </div>

                <div className="flex justify-center mt-8">
                  <Button 
                    onClick={handleGenerate}
                    disabled={isGenerating || !researchTopic.trim() || !targetAudience.trim() || !researchPurpose.trim()}
                    className="bg-blue-600 hover:bg-blue-700 px-8"
                  >
                    {isGenerating ? (
                      <>
                        <Loader2 className="w-4 h-4 mr-2 animate-spin" />
                        {t('outline.generating')}
                      </>
                    ) : (
                      <>
                        <Brain className="w-4 h-4 mr-2" />
                        {t('outline.generateOutline')}
                      </>
                    )}
                  </Button>
                </div>
              </div>

              {/* 大纲展示区 */}
              {outlineData && !isEditing && (
                <div className="bg-white border border-slate-200 rounded-lg p-8 shadow-lg">
                  <div className="flex items-center justify-between mb-8">
                    <h2 className="text-xl font-bold text-slate-800">{t('outline.generatedOutline')}</h2>
                    <div className="flex space-x-3">
                      <Button onClick={handleEdit} variant="outline" className="text-slate-600 border-slate-300 hover:text-slate-800">
                        <Edit3 className="w-4 h-4 mr-2" />
                        {t('outline.edit')}
                      </Button>
                      <Button onClick={handleExport} variant="outline" className="text-slate-600 border-slate-300 hover:text-slate-800">
                        <Download className="w-4 h-4 mr-2" />
                        {t('outline.exportWord')}
                      </Button>
                    </div>
                  </div>
                  
                  <div className="text-center mb-8">
                    <h3 className="text-2xl font-bold text-slate-800 mb-3">{outlineData.project_title}</h3>
                    <p className="text-slate-500">{t('outline.interviewOutline')}</p>
                  </div>
                  
                  {outlineData.sections.map((section, index) => (
                    <div key={section.id || index} className="border-l-4 border-blue-500 pl-6 mb-8">
                      <div className="flex items-center justify-between mb-4">
                        <h4 className="text-lg font-semibold text-slate-800">{section.title}</h4>
                        <span className="text-sm text-slate-500 bg-slate-100 px-3 py-1 rounded">
                          <Clock className="w-3 h-3 inline mr-2" />
                          {section.duration}
                        </span>
                      </div>
                      
                      <div className="space-y-4">
                        <div>
                          <h5 className="font-medium text-slate-700 mb-3">{t('outline.questionList')}</h5>
                          <ul className="space-y-3">
                            {section.questions.map((question, qIndex) => (
                              <li key={qIndex} className="flex items-start">
                                <span className="text-blue-500 mr-3">•</span>
                                <span className="text-slate-700">{question}</span>
                              </li>
                            ))}
                          </ul>
                        </div>
                        
                        {section.notes && (
                          <div>
                            <h5 className="font-medium text-slate-700 mb-3">{t('outline.notes')}</h5>
                            <p className="text-slate-600 text-sm bg-slate-50 p-4 rounded">
                              {section.notes}
                            </p>
                          </div>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              )}

              {/* 编辑界面 */}
              {outlineData && isEditing && editingOutline && (
                <div className="bg-white border border-slate-200 rounded-lg p-8 shadow-lg">
                  <div className="flex items-center justify-between mb-8">
                    <h2 className="text-xl font-bold text-slate-800">{t('outline.editOutline')}</h2>
                  </div>
                  
                  <div className="bg-slate-50 rounded-lg p-6 mb-8 shadow-sm">
                    <Label className="text-slate-600 text-sm">{t('outline.projectTitle')}</Label>
                    <Input
                      value={editingOutline.project_title}
                      onChange={(e) => setEditingOutline({
                        ...editingOutline,
                        project_title: e.target.value
                      })}
                      className="mt-3 bg-white border-slate-300 text-slate-800"
                    />
                  </div>
                  
                  {editingOutline.sections.map((section, index) => (
                    <div key={section.id || index} className="bg-slate-50 rounded-lg p-6 mb-6 shadow-sm">
                      <div className="flex items-center justify-between mb-6">
                        <Input
                          value={section.title}
                          onChange={(e) => handleSectionEdit(index, 'title', e.target.value)}
                          className="bg-white border-slate-300 text-slate-800 font-medium"
                        />
                        <Button
                          onClick={() => removeSection(index)}
                          variant="outline"
                          size="sm"
                          className="text-red-500 border-red-300 hover:text-red-600"
                        >
                          <X className="w-4 h-4" />
                        </Button>
                      </div>
                      
                      <div className="grid grid-cols-2 gap-6 mb-6">
                        <div>
                          <Label className="text-slate-600 text-sm">{t('outline.duration')}</Label>
                          <Input
                            value={section.duration}
                            onChange={(e) => handleSectionEdit(index, 'duration', e.target.value)}
                            className="mt-3 bg-white border-slate-300 text-slate-800"
                          />
                        </div>
                      </div>
                      
                      <div className="mb-6">
                        <Label className="text-slate-600 text-sm">{t('outline.questionList')}</Label>
                        <div className="space-y-3 mt-3">
                          {section.questions.map((question, qIndex) => (
                            <Input
                              key={qIndex}
                              value={question}
                              onChange={(e) => {
                                const newQuestions = [...section.questions];
                                newQuestions[qIndex] = e.target.value;
                                handleSectionEdit(index, 'questions', newQuestions);
                              }}
                              className="bg-white border-slate-300 text-slate-800"
                              placeholder={`${t('outline.question')} ${qIndex + 1}`}
                            />
                          ))}
                        </div>
                      </div>
                      
                      <div>
                        <Label className="text-slate-600 text-sm">{t('outline.notes')}</Label>
                        <Textarea
                          value={section.notes}
                          onChange={(e) => handleSectionEdit(index, 'notes', e.target.value)}
                          className="mt-3 bg-white border-slate-300 text-slate-800"
                          placeholder={t('outline.notesPlaceholder')}
                          rows={3}
                        />
                      </div>
                    </div>
                  ))}
                  
                  <div className="flex space-x-3">
                    <Button onClick={addSection} variant="outline" className="text-slate-600 border-slate-300 hover:text-slate-800">
                      <Edit3 className="w-4 h-4 mr-2" />
                      {t('outline.addSection')}
                    </Button>
                    <Button onClick={handleSaveEdit} className="bg-green-600 hover:bg-green-700">
                      {t('outline.saveChanges')}
                    </Button>
                    <Button onClick={handleCancelEdit} variant="outline" className="text-slate-600 border-slate-300 hover:text-slate-800">
                      {t('outline.cancel')}
                    </Button>
                  </div>
                </div>
              )}
            </>
          )}

          {/* 分析工作区 - 实验室风格，标准双栏布局 */}
          {activeWorkbench === 'analysis' && (
            <div className="max-w-5xl mx-auto px-4">
              {/* 上传引导区 - 可收缩 */}
              <div className={`bg-white border border-slate-200 rounded-lg p-6 mb-6 shadow-sm transition-all duration-300 ${
                transcriptText ? 'py-3' : 'py-8'
              }`}>
                <div className="flex items-center justify-between">
                  <div>
                    <h2 className={`text-lg font-bold text-slate-800 mb-2 ${
                      transcriptText ? 'text-base' : 'text-xl'
                    }`}>{t('analysis.interviewAnalysis')}</h2>
                    <p className={`text-slate-500 text-sm ${
                      transcriptText ? 'hidden' : 'block'
                    }`}>{t('analysis.analysisDescription')}</p>
                  </div>
                  
                  <Button 
                    onClick={analyzeTranscript}
                    disabled={!transcriptText || isAnalyzing || apiKeyStatus !== 'ready'}
                    className="bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 text-white shadow-sm"
                    size="lg"
                  >
                    {isAnalyzing ? (
                      <>
                        <Loader2 className="w-4 h-4 mr-2 animate-spin" />
                        {t('analysis.analyzing')}
                      </>
                    ) : (
                      <>
                        <Brain className="w-4 h-4 mr-2" />
                        {t('analysis.runInsightAnalysis')}
                      </>
                    )}
                  </Button>
                </div>
              </div>

              {/* 标准双栏布局 */}
              <div className="grid grid-cols-5 gap-6">
                {/* 左栏 (60%) - 洞察结果区 */}
                <div className="col-span-3">
                  {analysisResult ? (
                    <div className="space-y-6">
                      {/* 背景段落 */}
                      <div className="bg-white border border-slate-200 rounded-lg p-6 shadow-sm">
                        <h4 className="font-medium text-slate-800 mb-4">{t('analysis.background')}</h4>
                        <p className="text-sm text-slate-600 bg-slate-50 p-4 rounded">
                          {analysisResult.background}
                        </p>
                      </div>

                      {/* 核心观点段落 */}
                      <div className="bg-white border border-slate-200 rounded-lg p-6 shadow-sm">
                        <h4 className="font-medium text-slate-800 mb-4">{t('analysis.coreInsights')}</h4>
                        <p className="text-sm text-slate-600 bg-green-50 p-4 rounded">
                          {analysisResult.coreInsights}
                        </p>
                      </div>

                      {/* 待办事项段落 */}
                      <div className="bg-white border border-slate-200 rounded-lg p-6 shadow-sm">
                        <h4 className="font-medium text-slate-800 mb-4">{t('analysis.actionItems')}</h4>
                        <p className="text-sm text-slate-600 bg-yellow-50 p-4 rounded">
                          {analysisResult.actionItems}
                        </p>
                      </div>

                      {/* 导出按钮 */}
                      <div className="flex space-x-3">
                        <Button onClick={exportFullReport} variant="outline" className="text-slate-600 border-slate-300 hover:text-slate-800">
                          <Download className="w-4 h-4 mr-2" />
                          {t('analysis.exportReport')}
                        </Button>
                      </div>
                    </div>
                  ) : (
                    /* 优雅空状态卡片 */
                    <div className="bg-white border border-slate-200 rounded-lg p-12 shadow-sm h-full min-h-[500px] flex items-center justify-center">
                      <div className="text-center">
                        <div className="w-20 h-20 bg-slate-100 rounded-full flex items-center justify-center mb-6 mx-auto">
                          <Brain className="w-10 h-10 text-slate-400" />
                        </div>
                        <h3 className="text-xl font-medium text-slate-600 mb-3">{t('analysis.waitingForTranscript')}</h3>
                        <p className="text-slate-500 text-sm max-w-md mx-auto">
                          {t('analysis.transcriptImportPrompt')}
                        </p>
                      </div>
                    </div>
                  )}
                </div>

                {/* 右栏 (40%) - 笔录上传和粘贴 */}
                <div className="col-span-2">
                  <div className="bg-white border border-slate-200 rounded-lg p-6 shadow-sm h-full">
                    <h4 className="font-medium text-slate-800 mb-6">{t('analysis.transcriptUpload')}</h4>
                    
                    {/* 文件上传区域 */}
                    <div className="mb-6">
                      <input
                        type="file"
                        accept=".txt,.docx"
                        onChange={handleFileUpload}
                        className="hidden"
                        id="file-upload"
                      />
                      <label 
                        htmlFor="file-upload" 
                        className="cursor-pointer inline-flex items-center space-x-3 px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors w-full justify-center"
                      >
                        <Upload className="w-4 h-4" />
                        {t('analysis.selectFile')}
                      </label>
                      <p className="text-sm text-slate-500 mt-3 text-center">{t('analysis.pasteBelow')}</p>
                    </div>

                    {/* 笔录内容输入 */}
                    <div className="mb-6">
                      <Label className="text-slate-600 text-sm">{t('analysis.transcriptContent')}</Label>
                      <Textarea
                        value={transcriptText}
                        onChange={(e) => setTranscriptText(e.target.value)}
                        className="min-h-40 mt-3 bg-white border border-slate-300 text-slate-800 placeholder-slate-400"
                        placeholder={t('analysis.transcriptPlaceholder')}
                        rows={12}
                      />
                    </div>

                    {/* 笔录预览区域 */}
                    {transcriptText && !analysisResult && (
                      <div>
                        <h4 className="font-medium text-slate-800 mb-4">{t('analysis.transcriptPreview')}</h4>
                        <div className="space-y-3 max-h-64 overflow-y-auto">
                          {transcriptChunks.map((chunk) => (
                            <div
                              key={chunk.id}
                              data-chunk-id={chunk.id}
                              className={`text-slate-600 text-sm p-3 rounded transition-all ${
                                highlightedChunkId === chunk.id 
                                  ? 'bg-blue-100 ring-2 ring-blue-500 ring-opacity-50' 
                                  : 'bg-slate-50'
                              }`}
                            >
                              {chunk.speaker && (
                                <span className="text-blue-600 font-medium">{chunk.speaker}：</span>
                              )}
                              <span className="whitespace-pre-wrap">{chunk.content}</span>
                            </div>
                          ))}
                        </div>
                      </div>
                    )}
                  </div>
                </div>
              </div>
            </div>
          )}
        </div>
      </div>

      {/* 右侧：Agent 对话框 - 抽屉式展开 */}
      {!isRightSidebarCollapsed && (
        <div className="fixed right-0 top-0 h-full w-96 bg-white border-l border-slate-200 shadow-lg z-50 transform transition-transform duration-300 ease-in-out">
          <div className="p-4 border-b border-slate-200">
            <div className="flex items-center justify-between">
              <div className="flex items-center">
                <Brain className="w-5 h-5 text-blue-600 mr-2" />
                <span className="font-medium text-slate-800">{t('agent.aiExpert')}</span>
              </div>
              <button
                onClick={() => setIsRightSidebarCollapsed(true)}
                className="text-slate-400 hover:text-slate-600 p-1"
              >
                <ChevronLeft className="w-4 h-4" />
              </button>
            </div>
          </div>
          
          {/* Agent 输出区域 - WelcomeGuide + 对话 */}
          <div className="relative" style={{ height: 'calc(100% - 120px)' }}>
            <div className="absolute inset-0 p-4 pb-20 overflow-hidden">
              {/* WelcomeGuide - 只在未交互时显示 */}
              {chatMessages.length === 0 && (
                <div className="mb-4">
                  <div className="bg-gradient-to-r from-blue-50 to-purple-50 border border-blue-200 rounded-lg p-4 shadow-sm">
                    <div className="flex items-center mb-3">
                      <Brain className="w-5 h-5 text-blue-600 mr-2" />
                      <span className="text-blue-800 font-medium text-sm">{t('agent.insightEngine')}</span>
                    </div>
                    <p className="text-slate-600 text-sm leading-relaxed">
                      {t('agent.welcome')}
                    </p>
                  </div>
                </div>
              )}
              
              {/* 对话区域 - 置顶撑满 */}
              <div 
                ref={chatContainerRef}
                className="space-y-3 overflow-y-auto"
                style={{ height: chatMessages.length > 0 ? '100%' : 'calc(100% - 120px)' }}
              >
              {chatMessages.map((message) => (
                <div
                  key={message.id}
                  className={`flex ${message.type === 'user' ? 'justify-end' : 'justify-start'} mb-3`}
                >
                  {message.type === 'user' ? (
                    <div className="text-right max-w-[80%]">
                      <p className="font-medium text-slate-800 text-sm inline-block bg-blue-50 px-3 py-2 rounded-l-lg rounded-tr-lg">
                        {message.content}
                      </p>
                    </div>
                  ) : (
                    <div className="max-w-[80%]">
                      <div className="flex items-start">
                        <Brain className="w-4 h-4 text-blue-600 mr-2 mt-0.5 flex-shrink-0" />
                        <p className="text-slate-600 text-sm leading-relaxed bg-slate-50 px-3 py-2 rounded-lg">
                          {message.content}
                          {/* 引用联动 - 可点击的原话 */}
                          {message.evidence && (
                            <button
                              onClick={() => scrollToEvidence(message.evidence!.chunkId)}
                              className="mt-2 text-blue-600 hover:text-blue-500 underline text-xs flex items-center"
                            >
                              <Search className="w-3 h-3 mr-1" />
                              {t('analysis.viewOriginal')}
                            </button>
                          )}
                        </p>
                      </div>
                    </div>
                  )}
                </div>
              ))}
            </div>
            
            {/* Agent 思考状态 */}
            {isAgentThinking && (
              <div className="flex items-center justify-center py-3">
                <div className="flex items-center space-x-2 text-blue-600 text-sm">
                  <Loader2 className="w-3 h-3 animate-spin" />
                  <span>{thinkingStep || t('agent.scanningTranscript')}</span>
                </div>
              </div>
            )}
            
            {/* 固定底部输入框 - 绝对置底 */}
          </div>
          </div>
          
          <div className="absolute bottom-0 left-0 right-0 border-t border-slate-200 bg-white p-2 z-30">
            <div className="flex space-x-2">
              <Input
                value={currentMessage}
                onChange={(e) => setCurrentMessage(e.target.value)}
                placeholder={t('agent.askMoreDetails')}
                className="bg-white border border-slate-300 text-slate-800 placeholder-slate-400 text-sm flex-1"
                onKeyPress={(e) => e.key === 'Enter' && handleChat()}
              />
              <Button
                onClick={handleChat}
                disabled={!currentMessage.trim() || isChatting}
                className="bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700"
              >
                <Zap className="w-4 h-4" />
              </Button>
            </div>
          </div>
        </div>
      )}

      {/* 右侧收起状态 - 引擎点火风格 */}
      {isRightSidebarCollapsed && (
        <div className="fixed right-0 top-1/2 transform -translate-y-1/2 z-40 group">
          <button
            onClick={() => setIsRightSidebarCollapsed(false)}
            className={`relative bg-gradient-to-r from-blue-600 to-purple-600 hover:from-blue-700 hover:to-purple-700 text-white rounded-l-full px-4 py-3 shadow-lg transition-all duration-300 ${
              isAnalyzing ? 'animate-pulse' : (analysisResult || chatMessages.length > 0 ? 'shadow-xl shadow-purple-500/25' : '')
            }`}
          >
            <div className="flex items-center space-x-2">
              <Zap className="w-5 h-5" />
              <span className="text-sm font-medium">{t('agent.launchInsight')}</span>
            </div>
            
            {/* 能量扩散效果 */}
            <div className="absolute inset-0 rounded-l-full bg-gradient-to-r from-blue-400/30 to-purple-400/30 animate-pulse" style={{ animationDuration: '2s' }} />
            
            {/* 运转效果 - 分析进行时显示 */}
            {isAnalyzing && (
              <div className="absolute -top-1 -right-1 w-3 h-3 bg-yellow-400 rounded-full animate-ping" />
            )}
            
            {/* 呼吸灯效果 - 当有新内容时显示 */}
            {!isAnalyzing && (analysisResult || chatMessages.length > 0) && (
              <div className="absolute -top-1 -right-1 w-2 h-2 bg-green-400 rounded-full animate-pulse" />
            )}
          </button>
          
          {/* 悬浮提示 */}
          <div className="absolute right-full top-1/2 transform -translate-y-1/2 mr-3 bg-slate-900 text-white rounded-lg px-3 py-2 text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none whitespace-nowrap shadow-lg">
            {t('agent.launchInsightTooltip')}
            <div className="absolute right-full top-1/2 transform -translate-y-1/2 w-0 h-0 border-t-4 border-t-transparent border-b-4 border-b-transparent border-r-4 border-r-slate-900"></div>
          </div>
        </div>
      )}

      {/* 全局错误Toast */}
      {showErrorToast && (
        <div className="fixed top-4 right-4 z-50 animate-in slide-in-from-right duration-300">
          <div className="bg-red-50 border border-red-200 rounded-lg p-4 shadow-2xl max-w-sm">
            <div className="flex items-start">
              <div className="flex-shrink-0">
                <div className="w-6 h-6 bg-red-500 rounded-full flex items-center justify-center">
                  <X className="w-4 h-4 text-white" />
                </div>
              </div>
              <div className="ml-3">
                <h3 className="text-red-800 font-medium text-sm">{t('errors.operationFailed')}</h3>
                <p className="text-red-600 text-sm mt-1">{errorMessage}</p>
              </div>
              <div className="ml-auto pl-3">
                <button
                  onClick={() => setShowErrorToast(false)}
                  className="text-red-400 hover:text-red-600 transition-colors"
                >
                  <X className="w-4 h-4" />
                </button>
              </div>
            </div>
          </div>
        </div>
      )}

      {/* 左下角用户头像组件 */}
      <div className="fixed bottom-6 left-6 z-30 group">
        <button className="w-12 h-12 bg-slate-900 rounded-full flex items-center justify-center shadow-lg hover:shadow-xl transition-all duration-300">
          <Bot className="w-6 h-6 text-white" />
        </button>
        
        {/* Tooltip */}
        <div className="absolute bottom-full left-1/2 transform -translate-x-1/2 mb-2 bg-slate-900 text-white rounded-lg px-3 py-2 text-xs opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none whitespace-nowrap">
          {t('sidebar.aiExpert')}
          <div className="absolute top-full left-1/2 transform -translate-x-1/2 w-0 h-0 border-l-4 border-l-transparent border-r-4 border-r-transparent border-t-4 border-t-slate-900"></div>
        </div>
      </div>
    </div>
  );
}
